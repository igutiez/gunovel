# Clave secreta de Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_me

# Rutas
NOVELAS_ROOT=/Users/igutiez/novelas
APP_CONFIG_DIR=/Users/igutiez/novela-app-config

# API de Anthropic (pegar cuando se active el módulo IA)
ANTHROPIC_API_KEY=

# Configuración de sesión
SESSION_LIFETIME_HOURS=8

# Tasa USD→EUR para cálculo de coste
USD_TO_EUR=0.92

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Logging
LOG_LEVEL=INFO
LOG_DIR=/Users/igutiez/novela-app-config/logs
